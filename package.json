{
  "name": "@velaros/html-artifacts",
  "version": "0.1.0",
  "description": "A streaming HTML artifact protocol and sandboxed iframe runtime extracted from VelarOS.",
  "keywords": [
    "ai",
    "artifact",
    "html",
    "iframe",
    "streaming"
  ],
  "license": "MIT",
  "author": "Error-Zhang",
  "homepage": "https://github.com/Error-Zhang/VelarOS-HTML-Artifacts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Error-Zhang/VelarOS-HTML-Artifacts.git"
  },
  "bugs": {
    "url": "https://github.com/Error-Zhang/VelarOS-HTML-Artifacts/issues"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox.d.ts",
      "import": "./dist/sandbox.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.mjs",
    "demo": "npm run build && vite demo",
    "demo:build": "npm run build && vite build demo --outDir ../demo-dist --emptyOutDir",
    "check": "npm run typecheck && npm test && npm run demo:build && npm pack --dry-run",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^7.3.2"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
